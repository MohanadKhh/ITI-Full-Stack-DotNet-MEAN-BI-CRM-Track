  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>ITI_DataSource</DataSourceName>
        <CommandText>select s.[St_Fname] + ' ' + s.[St_Lname] as Fullname, c.[Crs_Name], sc.grade
from [dbo].[Course] c, [dbo].[Stud_Course] sc, [dbo].[Student] s
where c.[Crs_Id] = sc.[Crs_Id] and s.[St_Id] = sc.[St_Id]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Fullname">
          <DataField>Fullname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Crs_Name">
          <DataField>Crs_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="grade">
          <DataField>grade</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
