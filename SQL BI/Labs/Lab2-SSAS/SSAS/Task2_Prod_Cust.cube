  <MdxScripts>
    <MdxScript dwd:design-time-name="5445a89a-7293-4a16-985d-d4d889e971d6">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Unite Price]
 AS [Measures].[Qty Total Price]/[Measures].[Qty], 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
      <CalculationProperties>
        <CalculationProperty dwd:design-time-name="a87736d9-9a03-4508-a7cc-dccbb8edebc9">
          <CalculationReference>[Measures].[Sales Unite Price]</CalculationReference>
          <CalculationType>Member</CalculationType>
          <Translations>
            <Translation dwd:design-time-name="8b60f131-1a74-4a64-b018-b460b467bcdc">
              <Language>3073</Language>
              <Caption>متوسط سعر الكمية</Caption>
            </Translation>
          </Translations>
        </CalculationProperty>
      </CalculationProperties>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="7f82c644-4fb9-4996-8498-7fd31bdebfed">
      <ID>KPI</ID>
      <Name>Qty_KPI</Name>
      <AssociatedMeasureGroupID>Fact Sales</AssociatedMeasureGroupID>
      <Value>[Measures].[Qty]</Value>
      <Goal>25</Goal>
      <Status>Case
    when kpivalue("Qty_KPI") &gt; 25 then 1
    when kpivalue("Qty_KPI") &lt; 25 then -1
    else 0
end</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Shapes</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>