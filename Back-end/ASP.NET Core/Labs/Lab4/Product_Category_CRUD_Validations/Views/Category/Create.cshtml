@model CategoryVM

<form action="~/Category/Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row py-1">
        <div class="col">
            @Html.LabelFor(c => c.Name, new { @class = "form-label" })
            @Html.TextBoxFor(c => c.Name, new {
            @class = "form-control",
                        @required = "required",
                        @placeholder = "Category Name",

                        })
            @Html.ValidationMessageFor(c => c.Name,null , new { @class = "text-danger" })
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-success px-4">
                Create Category
            </button>

            @Html.ActionLink("Cancel", "Index", "Category", null, new { @class = "btn btn-secondary" })
        </div>
    </div>

</form>