@using ECommerce.BLL
@model ProductReadVM

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th scope="col">#ID</th>
            <th scope="col">Name</th>
            <th scope="col">Price</th>
            <th scope="col">Count</th>
            <th scope="col">Category</th>
            <th scope="col">Expiration Date</th>
            <th scope="col">Image</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Model.Id</td>
            <td>@Model.Name</td>
            <td>@Model.Price</td>
            <td>@Model.Count</td>
            <td>@Model.CategoryName</td>
            <td>@Model.ExpiryDate</td>
            <td>
                <img src="~/Images/Products/@Model.ImagePath" class="img-thumbnail" style="width: 100px; height: 100px;" />
            </td>
        </tr>
    </tbody>
</table>
