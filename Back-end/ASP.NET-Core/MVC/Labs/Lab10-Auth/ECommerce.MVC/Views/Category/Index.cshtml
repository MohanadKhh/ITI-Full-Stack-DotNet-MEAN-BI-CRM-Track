@model IEnumerable<CategoryVM>


<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Products Count</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @{
            int i = 1;
        }
        @foreach (var category in Model)
        {
            <tr>
                <th scope="row">@i</th>
                <td>@category.Name</td>
                <td>@category.ProductCounts</td>
                <td>
                    <a class="btn btn-primary"
                       asp-action="Details"
                       asp-route-id="@category.Id">
                        Details
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-warning"
                           asp-action="Edit"
                           asp-route-id="@category.Id">
                            Edit
                        </a>
                        <button type="button" class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#delModal"
                                data-categoryid="@category.Id"
                                data-categoryname="@category.Name">
                            Delete
                        </button>
                    }
                </td>
            </tr>
            i++;
        }
    </tbody>

    <tfoot>
        <tr>
            <td colspan="7">
                <a href="~/Category/Create" class="btn btn-success">
                    Create Category
                </a>
            </td>
        </tr>
    </tfoot>
</table>


<!-- Modal -->
<div class="modal fade" id="delModal" tabindex="-1" aria-labelledby="delModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Delete Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are You sure to delete category "<b id="categoryName"></b>" ?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" id="delBtn" class="btn btn-danger">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#delModal').on('show.bs.modal' ,function(event){
            var button = $(event.relatedTarget)
            var categoryId = button.data('categoryid')
            var categoryName = button.data('categoryname')

            $('#categoryName').text(categoryName)

            $('#delBtn').off('click').on('click', function(){
                window.location.href = `/Category/Delete/${categoryId}`
            })
        });
    </script>
}