@model IEnumerable<ProductReadVM>

<a class="btn btn-outline-info m-5 d-flex justify-content-center fw-bold"
       asp-action="SearchOnProductsByCategory"
       asp-controller="Product">
    Search By Category
</a>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Price</th>
            <th scope="col">Count</th>
            <th scope="col">Category</th>
            <th scope="col">Image</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @{
            int i = 1;
        }
        @foreach (var product in Model)
        {
            <tr>
                <th scope="row">@i</th>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>@product.Count</td>
                <td>@product.CategoryName</td>
                <td>
                    <img src="~/Images/Products/@product.ImagePath" class="img-thumbnail" style="width: 100px; height: 100px;" />
                </td>
                <td>
                    <a class="btn btn-primary"
                           asp-action="Details"
                           asp-route-id="@product.Id">
                        Details
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-warning"
                               asp-action="Edit"
                               asp-route-id="@product.Id">
                            Edit
                        </a>
                        <button type="button" class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#delModal"
                                data-productid="@product.Id"
                                data-productname="@product.Name">
                            Delete
                        </button>
                    }
                </td>
            </tr>
            i++;
        }
    </tbody>
    @if (User.IsInRole("Admin"))
    {
        <tfoot>
            <tr>
                <td colspan="7">
                    <a href="~/Product/Create" class="btn btn-success">
                        Create Product
                    </a>
                </td>
            </tr>
        </tfoot>
    }
</table>


<!-- Modal -->
<div class="modal fade" id="delModal" tabindex="-1" aria-labelledby="delModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Delete Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are You sure to delete product "<b id="productName"></b>" ?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" id="delBtn" class="btn btn-danger">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#delModal').on('show.bs.modal' ,function(event){
            var button = $(event.relatedTarget)
            var productId = button.data('productid')
            var productName = button.data('productname')

            $('#productName').text(productName)

            $('#delBtn').off('click').on('click', function(){
                window.location.href = `/Product/Delete/${productId}`
            })
        });
    </script>
}